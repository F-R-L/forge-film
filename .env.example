# Forge environment variables
# Copy this file to .env and fill in your keys.
# API keys go here — never put them in forge.yaml.

# ── LLM providers ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── ImageGen providers ─────────────────────────────────────────
# OpenAI DALL·E uses OPENAI_API_KEY above
FAL_API_KEY=            # Flux via fal.ai

# ── Video backends ─────────────────────────────────────────────
KLING_API_KEY=
KLING_API_SECRET=

# ── Scheduler defaults (overridden by forge.yaml) ──────────────
FORGE_WORKERS=4
FORGE_VIDEO_BACKEND=mock
OUTPUT_DIR=./output
